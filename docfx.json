{
    "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
    "metadata": [
        {
            "src": [
                {
                    "src": "./src",
                    "files": [
                        "**/*.Abstractions.csproj"
                    ],
                    "exclude": [
                        "**/bin/**",
                        "**/_bin/**",
                        "**/_bin_build/**",
                        "**/obj/**",
                        "**/_obj/**",
                        "**/ZYC.Framework.Build.*/**"
                    ]
                }
            ],
            "dest": "./_api"
        }
    ],
    "build": {
        "content": [
            {
                "files": [
                    "index.md",
                    "README*.md",
                    "LICENSE",
                    "docs/**.md",
                    "_api/**.yml"
                ],
                "exclude": [
                    "_site/**",
                    "**/bin/**",
                    "**/obj/**"
                ]
            }
        ],
        "resource": [
            {
                "files": [
                    "docs/images/**"
                ],
                "exclude": [
                    "_site/**",
                    "_api/**"
                ]
            }
        ],
        "output": "_site",
        "template": [
            "default"
        ]
    }
}